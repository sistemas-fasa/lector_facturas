# n8n / helper local
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=
INVOICE_OUTPUT_DIR=./home/ferreteria/n8n/data/facturas_parseadas/cola/pendientes
INVOICE_GENERATE_XML=false
DEDUPE_TTL_HOURS=168
DEDUPE_PHASH_HAMMING=8
INVOICE_HELPER_URL=http://127.0.0.1:8088

# Google Drive / mail
DRIVE_FOLDER_ID=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# MySQL FASA
FASA_MYSQL_DATABASE=
FASA_MYSQL_USER=
FASA_MYSQL_PASSWORD=
FASA_MYSQL_HOST=127.0.0.1
FASA_MYSQL_PORT=3306

# Workflow n8n: facturas reenviadas por mail
INVOICE_EMAIL_HELPER_URL=http://127.0.0.1:8088
INVOICE_EMAIL_WORKFLOW_NAME=lector_factura_email
INVOICE_EMAIL_FOLDER=INBOX
INVOICE_EMAIL_ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg
INVOICE_EMAIL_ALLOWED_SENDERS=
INVOICE_EMAIL_PARSE_TIMEOUT_MS=120000
INVOICE_QR_MAX_PAGES=2
INVOICE_QR_ZBAR_TIMEOUT_SECONDS=8
INVOICE_QR_MAX_VARIANTS=6
INVOICE_EMAIL_IMAP_POLL_ENABLED=false
INVOICE_EMAIL_IMAP_POLL_INTERVAL_SECONDS=300
INVOICE_EMAIL_IMAP_CREDENTIAL_ID=
INVOICE_EMAIL_IMAP_CREDENTIAL_NAME=

# Datos de referencia para crear/probar la credencial IMAP en n8n.
# El workflow usa la credencial de n8n; no guarda el password del mail en el JSON.
INVOICE_EMAIL_IMAP_HOST=
INVOICE_EMAIL_IMAP_PORT=993
INVOICE_EMAIL_IMAP_USER=
INVOICE_EMAIL_IMAP_PASSWORD=
INVOICE_EMAIL_IMAP_SSL=true

# =========================
# AI FIRST INVOICE EXTRACTOR
# =========================
INVOICE_AI_ENABLED=true
INVOICE_AI_PROVIDER=openrouter

# OpenRouter
# Crear una API key nueva desde el mismo usuario/workspace donde se revisa Usage.
# No usar variables viejas de Windows si se quiere probar este archivo: cargar este .env
# y pisar cualquier OPENROUTER_API_KEY previa del entorno.
OPENROUTER_API_KEY=

# Modelo recomendado para validar facturas reales.
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_MODEL=
INVOICE_AI_ALLOW_FREE_MODELS=false

# Opcion economica para pruebas controladas:
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
#
# Solo conectividad, no recomendado para facturas reales:
# OPENROUTER_MODEL=openrouter/free
# INVOICE_AI_ALLOW_FREE_MODELS=true

# Timeouts y reintentos
INVOICE_AI_TIMEOUT_SECONDS=60
INVOICE_AI_MAX_RETRIES=1

# Modo debug para revisar trazabilidad
INVOICE_AI_DEBUG=true

# Seguridad
INVOICE_AI_STORE_RAW_RESPONSE=true
INVOICE_AI_LOG_RAW_RESPONSE=false

# Validaciones locales obligatorias despues de la IA
INVOICE_AI_MIN_CONFIDENCE=0.70
INVOICE_AI_REQUIRE_CRITICAL_FIELDS=true
INVOICE_AI_TOTAL_TOLERANCE=2.00

# Fallback legacy: PyOCR/regex/QR solo quedan como fallback, no como solucion principal.
INVOICE_AI_FALLBACK_LEGACY=true

# =========================
# CODEX LOOP CONTROL
# =========================
CODEX_LOOP_ENABLED=true
CODEX_LOOP_MAX_ITERATIONS=5
CODEX_LOOP_STOP_ON_TEST_SUCCESS=true
CODEX_LOOP_RUN_TESTS_EACH_ITERATION=true
CODEX_LOOP_CREATE_PR_ONLY_IF_TESTS_PASS=true
CODEX_LOOP_COMMIT_ONLY_IF_TESTS_PASS=true

# Comandos de validacion
CODEX_TEST_COMMAND=python -m pytest -q
CODEX_EXTRA_CHECK_COMMAND=python -m compileall .

# Git / PR
CODEX_BRANCH_NAME=codex/ai-first-openrouter-extraction
CODEX_PR_DRAFT=true
CODEX_PR_BASE=main

# Reglas de correccion
CODEX_FIX_TEST_FAILURES=true
CODEX_FIX_LINT_FAILURES=true
CODEX_DO_NOT_PATCH_PYOCR_AS_MAIN_SOLUTION=true
CODEX_KEEP_LEGACY_AS_FALLBACK_ONLY=true

# Corte de seguridad
CODEX_STOP_IF_SAME_FAILURE_REPEATS=3
CODEX_STOP_IF_SCOPE_DRIFTS=true
