# =============================================================================
# FASA - invoice-parser environment example
# =============================================================================
# Copiar este archivo como .env en el servidor y completar los valores reales.
# NO versionar el .env real. Este example es solo referencia de configuración.
# =============================================================================

# --- Obligatorio para produccion con n8n ---
# El polling IMAP interno del sidecar Python debe estar DESHABILITADO cuando
# n8n ya lee la misma casilla por IMAP. Dos conexiones IMAP simultaneas
# (trigger IDLE de n8n + polling cada 60s del parser) provocan ECONNRESET
# con proveedores como Ferozo por limites de conexiones concurrentes.
INVOICE_EMAIL_IMAP_POLL_ENABLED=false

# --- IMAP (solo referencial - no usado en produccion FASA) ---
# Estos valores se mantienen como documentacion. En FASA productivo n8n
# es quien lee el correo, no el sidecar Python.
# INVOICE_EMAIL_IMAP_HOST=imap.ferozo.com
# INVOICE_EMAIL_IMAP_PORT=993
# INVOICE_EMAIL_IMAP_USER=facturas.ocr@fasa.ar
# INVOICE_EMAIL_IMAP_PASSWORD=
# INVOICE_EMAIL_FOLDER=INBOX
# INVOICE_EMAIL_ALLOWED_SENDERS=
# INVOICE_EMAIL_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# --- HTTP server ---
INVOICE_HELPER_HOST=0.0.0.0
INVOICE_HELPER_PORT=8765

# --- Output ---
INVOICE_OUTPUT_DIR=/home/ferreteria/n8n/data/facturas_parseadas
INVOICE_GENERATE_XML=true
# INVOICE_QUEUE_DIR=

# --- QR ---
INVOICE_QR_MAX_PAGES=2
INVOICE_QR_ZBAR_TIMEOUT_SECONDS=2
INVOICE_QR_MAX_VARIANTS=10

# --- Proveedores ---
# Ruta absoluta al JSON de perfiles por proveedor dentro del container.
# INVOICE_PROVIDER_PROFILES_FILE=

# --- Debug ---
# INVOICE_WRITE_DEBUG_TEXTS=false

# --- Tolerancia de total ---
# INVOICE_TOTAL_TOLERANCE=1.00

# --- MySQL staging (FASA) ---
# Completar con los valores reales de produccion.
# Se pueden usar FASA_MYSQL_* o MYSQL_* indistintamente.
FASA_MYSQL_HOST=db
FASA_MYSQL_PORT=3306
FASA_MYSQL_USER=root
# FASA_MYSQL_PASSWORD=
FASA_MYSQL_DATABASE=fasa

# --- n8n helper URL (para scripts de creacion de workflow) ---
# INVOICE_HELPER_URL=http://invoice-parser:8765
